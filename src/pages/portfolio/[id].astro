---
import portfolio_config from "@/portfolio-config.json";
import { parse } from "date-fns";
import IdHeader from "@/components/static/IdHeader.astro";
import IdLayout from "@/layouts/IdLayout.astro";
import PortfolioGallery from "@/components/static/PortfolioGallery.astro";
import PortfolioDetails from "@/components/static/PortfolioDetails.astro";
import type { ImageMetadata } from "astro";
import type { portfolioConfig } from "@/lib/types";
import { RiArrowRightUpLine, RiExternalLinkLine } from "@remixicon/react";

export function getStaticPaths() {
    return portfolio_config.map((item) => ({
        params: { id: item.id },
        props: { item },
    }));
}

const { item } = Astro.props;

const allItems = portfolio_config.sort((a, b) => {
    const dateA = parse(a.data.date, "dd-MM-yyyy", new Date());
    const dateB = parse(b.data.date, "dd-MM-yyyy", new Date());
    return dateB.getTime() - dateA.getTime();
});

const currentIndex = allItems.findIndex((i) => i.id === item.id);
const prev = currentIndex > 0 ? allItems[currentIndex - 1] : null;
const next = currentIndex < allItems.length - 1 ? allItems[currentIndex + 1] : null;

const pubDate = parse(item.data.date, "dd-MM-yyyy", new Date());

type ImageRecord = { default: ImageMetadata };
const imageModules = import.meta.glob<ImageRecord>("@/assets/portfolio/*/*.{png,jpg,jpeg,webp,gif,avif}", { eager: true });
const projectImages = Object.entries(imageModules)
    .filter(([path]) => path.includes(`/assets/portfolio/${item.id}/`))
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([, mod]) => mod.default);

const links = item?.links ?? [];
---

<IdLayout type="portfolio" title={item.data.title} description={item.data.description} image={`/og/portfolio/${item.id}.png`} pubDate={pubDate} tags={item.data.tags} prev={prev} next={next}>
    <article transition:animate="fade">
        <IdHeader backUrl="/portfolio" items={item.data} />

        <div class="mt-10">
            {
                links.length > 0 && (
                    <div class="w-full flex flex-wrap p-3 border border-border border-b-0">
                        <RiExternalLinkLine className="size-4 ml-3 my-auto text-secondary-foreground/90" />
                        {links.map((link) => (
                            <a href={link.url} target="_blank" rel="noopener noreferrer" class="ml-3 text-sm text-muted-foreground/80 hover:text-secondary-foreground/90 hover:underline underline-offset-3 hover:underline-offset-6 animation active:text-background active:bg-secondary-foreground px-1">
                                {link.label}
                            </a>
                        ))}
                    </div>
                )
            }
            <PortfolioGallery item={item as portfolioConfig} images={projectImages} />
            <PortfolioDetails item={item as portfolioConfig} />
        </div>
    </article>
</IdLayout>

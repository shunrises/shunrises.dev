---
import IdHeader from "@/components/static/IdHeader.astro";
import IdLayout from "@/layouts/IdLayout.astro";
import { getCollection, render } from "astro:content";
import { parse } from "date-fns";

export async function getStaticPaths() {
    const items = (await getCollection("blog")).filter((item) => !item.data.draft);
    return items.map((item) => ({
        params: { id: item.id },
        props: { item },
    }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const allItems = (await getCollection("blog"))
    .filter((item) => !item.data.draft)
    .sort((a, b) => {
        const dateA = parse(a.data.date, "dd-MM-yyyy", new Date());
        const dateB = parse(b.data.date, "dd-MM-yyyy", new Date());
        return dateA.getTime() - dateB.getTime();
    });

const currentIndex = allItems.findIndex((i) => i.id === item.id);
const prev = currentIndex > 0 ? allItems[currentIndex - 1] : null;
const next = currentIndex < allItems.length - 1 ? allItems[currentIndex + 1] : null;

const pubDate = parse(item.data.date, "dd-MM-yyyy", new Date());
---

<IdLayout
    type="blog"
    title={item.data.title}
    description={item.data.description}
    image={`/og/blog/${item.id}.png`}
    pubDate={pubDate}
    author={item.data.author}
    tags={item.data.tags}
    prev={prev}
    next={next}
>
    <article transition:animate="fade">
        <IdHeader backUrl="/blog" items={item.data} />

        <div class="mt-10 prose border border-border p-6">
            <Content />
        </div>
    </article>
</IdLayout>

---
import site_config from "@/site-config.json";
import portfolio_config from "@/portfolio-config.json";
import { parse } from "date-fns";
import { getImage } from "astro:assets";
import { FeaturedPortfolioCard } from "../client/FeaturedPortfolioCard";
import type { portfolioConfig } from "@/lib/types";
import type { ImageMetadata } from "astro";
import { RiArrowRightUpLine } from "@remixicon/react";

const projects = portfolio_config.sort((a, b) => {
    const dateA = parse(a.data.date, "dd-MM-yyyy", new Date());
    const dateB = parse(b.data.date, "dd-MM-yyyy", new Date());
    return dateB.getTime() - dateA.getTime();
});

type ImageRecord = { default: ImageMetadata };
const imageModules = import.meta.glob<ImageRecord>("@/assets/portfolio/*/*.{png,jpg,jpeg,webp,gif,avif}", { eager: true });

const enriched = await Promise.all(
    projects.map(async (item) => {
        const matches = Object.entries(imageModules)
            .filter(([path]) => path.includes(`/assets/portfolio/${item.id}/`))
            .sort(([a], [b]) => a.localeCompare(b))
            .map(([, mod]) => mod.default);

        let heroImage: string | undefined;
        if (matches.length > 0) {
            const optimized = await getImage({ src: matches[0], width: 600 });
            heroImage = optimized.src;
        }

        return { ...item, heroImage };
    }),
);
---

{
    site_config.featured.portfolio.visible && projects.length > 0 && (
        <section class="bg-background border border-border p-6 mt-10">
            <a href="/portfolio" class="flex items-center justify-start group w-fit gap-2 select-none">
                <span class="text-muted-foreground group-hover:text-secondary-foreground animation font-geist">things i've made</span>
                <RiArrowRightUpLine className="size-0 group-hover:size-4 scale-0 group-hover:scale-100 opacity-0 group-hover:opacity-100 animation" />
            </a>
            <div class="mt-6">
                <FeaturedPortfolioCard items={enriched as (portfolioConfig & { heroImage?: string })[]} client:load />
            </div>
        </section>
    )
}
